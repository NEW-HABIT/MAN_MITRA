# ─────────────────────────────────────────────────────────────────────────────
# ManMitra — Environment Variables Template
# Copy this file to .env and fill in the values.
# NEVER commit your actual .env file to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Django Core ──────────────────────────────────────────────────────────────
SECRET_KEY=django-insecure-replace-me-with-a-strong-secret-key-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_SETTINGS_MODULE=config.settings.development

# ── Frontend URL (used in emails) ────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ── Database (Production only — SQLite3 used in dev, no config needed) ───────
# DB_NAME=manmitra_db
# DB_USER=manmitra_user
# DB_PASSWORD=your_db_password
# DB_HOST=localhost
# DB_PORT=5432

# ── Email ─────────────────────────────────────────────────────────────────────
DEFAULT_FROM_EMAIL=ManMitra <noreply@manmitra.ai>
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=your_email@gmail.com
# EMAIL_HOST_PASSWORD=your_app_password

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Get these from Google Cloud Console → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ── AI Configuration ─────────────────────────────────────────────────────────
AI_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_api_key_here
# OPENAI_API_KEY=your_openai_api_key_here

# ── CORS (Production) ─────────────────────────────────────────────────────────
# CORS_ALLOWED_ORIGINS=https://manmitra.ai,https://www.manmitra.ai
